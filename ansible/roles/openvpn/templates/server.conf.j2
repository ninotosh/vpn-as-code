tls-server
dev tun
topology subnet
<peer-fingerprint>
{{ fingerprints_result.stdout }}
</peer-fingerprint>
cert {{ openvpn_server_crt }}
key {{ openvpn_server_key }}
{% if external_ipv6_address %}
local {{ ansible_facts['default_ipv6']['address'] }} 443 tcp6-server
server-ipv6 {{ network_openvpn_ipv6_ula_network }}
push "redirect-gateway ipv6"
push "dns server 0 address 2606:4700:4700::1111 2001:4860:4860::8888"
{% endif %}
local {{ ansible_facts['default_ipv4']['address'] }} 443 tcp-server
push "dns server 0 address 1.1.1.1 8.8.8.8"
tcp-nodelay
server {{ network_openvpn_ipv4_address }} {{ network_ipv4_netmask }}
push "redirect-gateway def1 bypass-dhcp"
keepalive 10 120
tls-crypt-v2 {{ openvpn_server_tls_crypt_v2 }}
cipher AES-256-GCM
auth SHA256
status /var/log/openvpn/status.log
status-version 2
verb 3
{% if ansible_facts['service_mgr'] == 'sysvinit' %}
log /var/log/openvpn/server.log
{% endif %}
