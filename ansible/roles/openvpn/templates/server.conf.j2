tls-server
dev tun
topology subnet
<peer-fingerprint>
{{ fingerprints_result.stdout }}
</peer-fingerprint>
cert {{ openvpn_server_crt }}
key {{ openvpn_server_key }}
{% if external_ipv6_address %}
local {{ ansible_default_ipv6.address }} 443 tcp6-server
local {{ ansible_default_ipv6.address }} 53 udp6
server-ipv6 {{ ipv6_ula_network }}
push "redirect-gateway ipv6"
push "dns server 0 address 2606:4700:4700::1111 2001:4860:4860::8888"
{% endif %}
local {{ ansible_default_ipv4.address }} 443 tcp-server
local {{ ansible_default_ipv4.address }} 53 udp
push "dns server 0 address 1.1.1.1 8.8.8.8"
tcp-nodelay
server {{ masquerade_ipv4_network }} {{ masquerade_ipv4_netmask }}
push "redirect-gateway def1 bypass-dhcp"
keepalive 10 120
tls-crypt-v2 {{ openvpn_server_tls_crypt_v2 }}
cipher AES-256-GCM
auth SHA256
status /var/log/openvpn/status.log
status-version 2
verb 3
